{
  "name": "redlizard-template",
  "version": "0.1.0",
  "description": "Scaffolder de proyectos Next.js + TypeScript + Supabase con seguridad end-to-end y tooling de Claude Code (MCP + Skills) preconfigurado.",
  "type": "module",
  "license": "UNLICENSED",
  "bin": {
    "redlizard-template": "dist/index.js"
  },
  "repository": {
